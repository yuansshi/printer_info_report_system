# Optional overrides for the remote service. Do not put the IMAP authorization
# code here; keep it in the file referenced by PRINTER_ENV_FILE.
PRINTER_ENV_FILE=/etc/printer-dashboard/mail.env
PRINTER_MAPPING_PATH=/var/lib/printer-dashboard/客户名称机身编号映射表.xlsx
PRINTER_DATA_ROOT=/var/lib/printer-dashboard/history
PRINTER_DASHBOARD_BUILDER=/opt/printer-dashboard/dashboard/build_data.mjs
PRINTER_DASHBOARD_OUTPUT=/var/www/printer-dashboard/data.js
PRINTER_NODE_BIN=/usr/bin/node
PRINTER_START_DATE=2026-06-01
PRINTER_TIMEZONE=Asia/Shanghai
